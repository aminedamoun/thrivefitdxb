# /server/.env  (NO comments or quotes needed beyond normal values)
PORT=8080
CORS_ORIGIN=https://www.thrivefitdxb.com

SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=careers@thrivefitdxb.com
SMTP_PASS=YOUR_SMTP_PASSWORD
NOTIFY_TO=info@thrivefitdxb.com
NOTIFY_FROM="ThriveFit Careers" <careers@thrivefitdxb.com>

# If you want R2 uploads ON:
S3_ENABLED=true
S3_REGION=auto
S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
S3_BUCKET=thrivefit-careers
S3_ACCESS_KEY_ID=xxxxxxxx
S3_SECRET_ACCESS_KEY=xxxxxxxx
SIGNED_URL_TTL_SECONDS=86400
